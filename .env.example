
# ── cal.com scheduling (optional — feature off when unset) ──
# API key: cal.com → Settings → Developer → API keys
CALCOM_API_KEY=
# Event type id: the number in app.cal.com/event-types/<id>
CALCOM_EVENT_TYPE_ID=
# CALCOM_API_BASE=https://api.cal.com/v2
# CALCOM_TIMEZONE=Asia/Singapore

# Wingman demo
WINGMAN_OPEN_DEMO=true

# Your Telegram numeric user id — approvals, FYIs, and owner commands route
# here. Get it from @userinfobot on Telegram.
WINGMAN_OWNER_TELEGRAM_ID=
